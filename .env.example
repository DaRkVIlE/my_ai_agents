# ── Evolution API ──────────────────────────────────────────
EVOLUTION_API_URL=https://evolution.kairos-os.com
EVOLUTION_GLOBAL_APIKEY=your_global_apikey_here
INSTANCE_NAME=your_default_instance_name

# ── Groq (Whisper + LLaMA) ─────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── LLM Fallback ───────────────────────────────────────────
LLM_PRIMARY=groq          # groq | sambanova
LLM_FALLBACK=sambanova    # groq | sambanova
SAMBANOVA_API_KEY=your_sambanova_api_key_here

# ── Redis (sessões persistentes) ───────────────────────────
# Use REDIS_PRIVATE_URL para Railway (rede interna)
# Use REDIS_URL para conexão pública
REDIS_PRIVATE_URL=redis://default:password@host:6379
REDIS_URL=redis://default:password@host:6379

# ── App ────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ── AIDA — Telegram Bot ─────────────────────────────────────
# Obtenha com @BotFather no Telegram: /newbot
AIDA_TELEGRAM_TOKEN=your_telegram_bot_token_here

# IDs do Telegram de admins (Gabriel), separados por vírgula
# Para descobrir seu ID: envie uma msg para @userinfobot no Telegram
AIDA_ADMIN_IDS=your_telegram_user_id_here

# ── AIDA — PostgreSQL (Railway) ─────────────────────────────
# Railway gera DATABASE_URL automaticamente ao adicionar PostgreSQL
# Disponível em: Railway Dashboard → seu projeto → PostgreSQL → Variables
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── AIDA — Google Sheets (opcional para backup/reports) ─────
# Não necessário para o MVP — PostgreSQL é suficiente
# GOOGLE_SHEETS_ID=your_sheet_id_here
# GOOGLE_SERVICE_ACCOUNT_KEY=your_base64_encoded_key_here

# ─────────────────────────────────────────────────────────────
# MANAGER ONBOARDING SYSTEM (Novo)
# ─────────────────────────────────────────────────────────────

# ── MongoDB Atlas (Manager Profiles & Configurations) ───────
# Obtenha em: https://www.mongodb.com/cloud/atlas
# Formato: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=commercial-ai-bots

# ── LibreChat Integration (Opcional) ────────────────────────
# Se integrado com LibreChat para onboarding de gestores
# LIBRECHAT_API_KEY=your_librechat_api_key
# LIBRECHAT_URL=http://localhost:3000
# LIBRECHAT_ENABLE_MANAGER_SYSTEM=true

# ── Manager System Options ──────────────────────────────────
# Ativar auditoria completa de ações de gestores
MANAGER_AUDIT_ENABLED=true

# Retenção de histórico de configurações (dias)
MANAGER_CONFIG_RETENTION_DAYS=90

# Email para notificações de onboarding (opcional)
# MANAGER_NOTIFICATION_EMAIL=admin@company.com
