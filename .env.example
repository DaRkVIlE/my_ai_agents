# ── Evolution API ──────────────────────────────────────────
EVOLUTION_API_URL=https://evolution.kairos-os.com
EVOLUTION_GLOBAL_APIKEY=your_global_apikey_here
INSTANCE_NAME=your_default_instance_name

# ── Groq (Whisper + LLaMA) ─────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── LLM Fallback ───────────────────────────────────────────
LLM_PRIMARY=groq          # groq | sambanova
LLM_FALLBACK=sambanova    # groq | sambanova
SAMBANOVA_API_KEY=your_sambanova_api_key_here

# ── Redis (sessões persistentes) ───────────────────────────
# Use REDIS_PRIVATE_URL para Railway (rede interna)
# Use REDIS_URL para conexão pública
REDIS_PRIVATE_URL=redis://default:password@host:6379
REDIS_URL=redis://default:password@host:6379

# ── App ────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
