{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "tenants": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "tenant_id": { "type": "string" },
          "active": { "type": "boolean" },
          "last_published_version": { "type": ["number", "null"] }
        },
        "required": ["tenant_id"]
      }
    }
  },
  "required": ["tenants"]
}
